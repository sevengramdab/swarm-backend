# OrbitScribe Swarm Backend Configuration

# API Mode: local_only | cloud_only | hybrid
SWARM_API_MODE=hybrid

# Backend port
SWARM_PORT=58081

# Gemini API key (required for cloud mode)
GEMINI_API_KEY=

# Ollama URL
OLLAMA_URL=http://127.0.0.1:11434

# LM Studio URL
LMSTUDIO_URL=http://127.0.0.1:1234
